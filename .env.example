APP_NAME="MyTakii Intranet"
APP_ENV=local
APP_URL=http://127.0.0.1:8080
APP_LOCALE=tr-TR
APP_SESSION_SECRET=
APP_ADMIN_EMAIL=admin@example.test
APP_ADMIN_PASSWORD=
APP_ADMIN_NAME="Company Administrator"
APP_ADMIN_ROLE="System Administrator"
APP_ADMIN_DEPARTMENT="Administration"
APP_ADMIN_STARTED_ON=
APP_HR_EMAIL=hr@example.test
APP_HR_PASSWORD=
APP_HR_NAME="Human Resources"
APP_HR_ROLE="HR Manager"
APP_HR_DEPARTMENT="HR"
APP_HR_STARTED_ON=
PASSWORD_RESET_MAIL_TRANSPORT=smtp
MAIL_TRANSPORT=smtp
MAIL_FROM_ADDRESS=no-reply@example.test
MAIL_FROM_NAME="MyTakii Intranet"
LEAVE_BOOK_SIGNATURE_FOLLOWUP_EMAILS=
LEAVE_BOOK_SIGNATURE_FOLLOWUP_DAYS=2
LEAVE_BOOK_SIGNATURE_TOKEN_TTL_DAYS=14
RELEASE_NOTE_RECIPIENTS=
SMTP_HOST=smtp.example.test
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ENCRYPTION=ssl
SMTP_VERIFY_PEER=true
SENDMAIL_PATH=/usr/sbin/sendmail
VAPID_SUBJECT=http://127.0.0.1:8080
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
SESSION_IDLE_TTL_SECONDS=1800
SESSION_ABSOLUTE_TTL_SECONDS=43200
TRUST_PROXY=false

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kanso_intranet
DB_USERNAME=root
DB_PASSWORD=

# Generate once with: php -r 'echo base64_encode(random_bytes(32)), PHP_EOL;'
# Keep this key outside source control and back it up securely. Losing it makes
# encrypted MariaDB state documents unrecoverable.
APP_DATA_ENCRYPTION_KEY=
APP_DATA_ENCRYPTION_PREVIOUS_KEYS=

# Absolute path to a confidential JSON organization plan outside this repository.
PERSONNEL_ORGANIZATION_PLAN=

# Production must use mariadb. The file driver is only for local recovery/tests
# and uses exclusive locks plus atomic file replacement.
STATE_STORE_DRIVER=mariadb
# scripts/migrate-state-to-mariadb.php creates the schema; keep this false in production.
STATE_STORE_AUTO_MIGRATE=false
STATE_STORE_LOCK_TIMEOUT=10
