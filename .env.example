APP_NAME="MyTakii Intranet"
APP_ENV=local
APP_URL=http://127.0.0.1:8080
APP_LOCALE=tr-TR
APP_SESSION_SECRET=
APP_ADMIN_EMAIL=bilal@bigabilisim.com
APP_ADMIN_PASSWORD=
APP_HR_EMAIL=y.ekici@takii.com.tr
APP_HR_PASSWORD=
PASSWORD_RESET_MAIL_TRANSPORT=outbox
MAIL_TRANSPORT=smtp
MAIL_FROM_ADDRESS=bilgilendirme@alarmbigabilisim.com
MAIL_FROM_NAME="MyTakii Intranet"
LEAVE_BOOK_SIGNATURE_FOLLOWUP_EMAILS=
LEAVE_BOOK_SIGNATURE_FOLLOWUP_DAYS=2
LEAVE_BOOK_SIGNATURE_TOKEN_TTL_DAYS=14
SMTP_HOST=mail.alarmbigabilisim.com
SMTP_PORT=465
SMTP_USERNAME=bilgilendirme@alarmbigabilisim.com
SMTP_PASSWORD=
SMTP_ENCRYPTION=ssl
SMTP_VERIFY_PEER=true
SENDMAIL_PATH=/usr/sbin/sendmail
VAPID_SUBJECT=http://127.0.0.1:8080
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
SESSION_IDLE_TTL_SECONDS=1800
SESSION_ABSOLUTE_TTL_SECONDS=43200
TRUST_PROXY=false

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kanso_intranet
DB_USERNAME=root
DB_PASSWORD=

# Production must use mariadb. The file driver is only for local recovery/tests
# and uses exclusive locks plus atomic file replacement.
STATE_STORE_DRIVER=mariadb
STATE_STORE_AUTO_MIGRATE=true
STATE_STORE_LOCK_TIMEOUT=10
